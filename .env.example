# Copy this file to `.env` and fill in your API key.
# `.env` is gitignored — never commit it.

# -----------------------------------------------------------------------------
# Default model the curriculum points at.
#
# This uses LiteLLM's model-string format. To swap providers, change this line
# AND uncomment the matching key below. See https://docs.litellm.ai/docs/providers
# for the full list of supported model strings.
# -----------------------------------------------------------------------------
LITELLM_MODEL=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# Provider API keys — uncomment + paste the key for the provider you chose above.
# You only need ONE of these for the curriculum to work.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# General config
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
